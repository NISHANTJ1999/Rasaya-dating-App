{
  "expo": {
    "name": "Rasaya",
    "slug": "rasaya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rasaya",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rasaya.app",
      "jsEngine": "hermes",
      "infoPlist": {
        "NSCameraUsageDescription": "Rasaya uses your camera to take verification selfies so we can confirm your profile is real.",
        "NSPhotoLibraryUsageDescription": "Rasaya needs access to your photos so you can add them to your profile.",
        "NSPhotoLibraryAddUsageDescription": "Rasaya saves photos you take to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.rasaya.app",
      "edgeToEdgeEnabled": true,
      "jsEngine": "hermes",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rasaya needs access to your photos so you can add them to your profile."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Rasaya uses your camera to take verification selfies so we can confirm your profile is real."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": { "deploymentTarget": "15.1" },
          "android": { "minSdkVersion": 24, "enableProguardInReleaseBuilds": true }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
